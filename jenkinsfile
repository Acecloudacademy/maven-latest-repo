pipeline {
    // add your slave label name
    agent { label 'slave-name'}
    tools{
        maven 'mvn'
    }
    stages {
        stage ('Checkout_SCM') {

            steps {
          	    
	     checkout scm
            }
        }

        stage ('Maven_Build') {

            steps {
               sh 'mvn clean package'
            }
        }
        
        stage ('Deploy_Tomcat') {

            steps {
	      sshagent(['tomcat']) {
              sh "scp -o StrictHostKeyChecking=no  target/maven-web-application.war  ec2-user@12.34.54.111:/opt/tomcat11/webapps"
	      }
         }
        }
        
    }
}
